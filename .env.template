# monshaapi environment configuration
# Copy to `.env` and adjust. Every value has a sane default in
# backend/core/conf.py, so you only need to override what differs.
#
# When running with docker-compose, the database/redis/minio hosts are
# overridden to the container service names by the compose file, so the
# localhost values below are meant for bare-metal local development.

# Environment: dev | preprod | prod
ENVIRONMENT=dev

# --- Database (Postgres) ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DATABASE=monshaapi

# Auto-create tables on startup (dev only). Set to false in production and use
# Alembic migrations instead.
DB_AUTO_CREATE=true

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DATABASE=0

# --- Object storage (MinIO / S3-compatible) ---
MINIO_ENDPOINT=localhost:9000
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_NAME=monshaapi
MINIO_CLOUD_URL=http://localhost:9000

# --- Secrets ---
# These dev defaults are fine for local work. Outside dev (ENVIRONMENT=preprod|prod)
# the server REFUSES to start until you replace them — along with POSTGRES_PASSWORD
# and MINIO_SECRET_KEY below.
# python -c "import secrets; print(secrets.token_urlsafe(32))"
TOKEN_SECRET_KEY=dev-insecure-change-me-token-secret-key
# python -c "import os; print(os.urandom(32).hex())"
OPERA_LOG_ENCRYPT_SECRET_KEY=dev-insecure-change-me-opera-log-key

# --- Optional: SMTP / email (leave blank to disable) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_TLS=True
SMTP_USER=
SMTP_PASSWORD=
EMAILS_FROM_EMAIL=
EMAILS_FROM_NAME=

# --- Optional: Google SSO ---
GOOGLE_CLIENT_ID=
GOOGLE_SECRET_KEY=
GOOGLE_WEBHOOK_OAUTH_REDIRECT_URI=

# --- Optional: external geo-IP lookup on each request (off by default) ---
# false  = disabled (recommended; no third-party call)
# online = sends each client IP to ip-api.com over HTTP (privacy + latency)
# offline = needs backend/static/ip2region.xdb (~11MB, not shipped)
IP_LOCATION_PARSE=false

# --- Optional: Observability (Prometheus / OpenTelemetry) ---
OBSERVABILITY_ENABLED=false
OTLP_GRPC_ENDPOINT=
